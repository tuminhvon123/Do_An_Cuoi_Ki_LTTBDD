<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tv_register"
        android:textSize="32sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/edtFullNameRegister"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/customer_name"
        android:layout_marginBottom="12dp"
        android:background="@android:drawable/editbox_background"
        android:paddingStart="16dp" />

    <EditText
        android:id="@+id/edtPhoneRegister"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/customer_phone"
        android:inputType="phone"
        android:layout_marginBottom="12dp"
        android:background="@android:drawable/editbox_background"
        android:paddingStart="16dp" />

    <EditText
        android:id="@+id/edtAddressRegister"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Địa chỉ giao hàng"
        android:layout_marginBottom="12dp"
        android:background="@android:drawable/editbox_background"
        android:paddingStart="16dp" />

    <EditText
        android:id="@+id/edtRegEmail"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/edt_email"
        android:inputType="textEmailAddress"
        android:background="@android:drawable/editbox_background"
        android:paddingStart="16dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/edtRegPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/edt_pass"
        android:inputType="textPassword"
        android:background="@android:drawable/editbox_background"
        android:paddingStart="16dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/edtRegConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/edt_passAgain"
        android:inputType="textPassword"
        android:background="@android:drawable/editbox_background"
        android:paddingStart="16dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/bt_register"
        android:textAllCaps="false"
        android:backgroundTint="@color/teal_primary"
        android:textSize="18sp"
        app:cornerRadius="12dp"/>

    <TextView
        android:id="@+id/tvGoBackLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tv_bLogin"
        android:textColor="@color/teal_primary"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:padding="8dp"/>

</LinearLayout>